# SentenceTransformer model for semantic scoring
# Options: all-MiniLM-L6-v2, all-MiniLM-L12-v2, all-mpnet-base-v2
ATS_EMBED_MODEL=all-MiniLM-L12-v2

# Ollama LLM for JD keyword expansion (leave empty to disable)
ATS_LLM_MODEL=qwen3.5:4b

# Enable cross-encoder reranking (1/true/yes to enable)
ATS_RERANK=false

# Page budget
# ATS_MAX_EXPERIENCE=3
# ATS_MAX_PROJECTS=4
# ATS_MIN_PROJECTS=4
# ATS_MAX_SKILL_LINES=4
# ATS_MAX_PROJECT_BULLETS=3
# ATS_MAX_EXP_BULLETS=3
# ATS_CHARS_PER_BULLET_LINE=80
# ATS_MAX_PAGE_LINES=72
