# SentenceTransformer model for semantic scoring
# Options: all-MiniLM-L6-v2, all-MiniLM-L12-v2, all-mpnet-base-v2
ATS_EMBED_MODEL=all-MiniLM-L12-v2

# Enable LLM keyword expansion (1/true/yes to enable)
# ATS_LLM_EXPAND=true

# LLM model name (default: qwen3.5:4b)
# ATS_LLM_MODEL=qwen3.5:4b

# LLM backend: auto (try MLX → LM Studio → Ollama), mlx, lmstudio, ollama
# ATS_LLM_BACKEND=auto

# LLM temperature: single-pass (default: 0.3)
# ATS_LLM_TEMPERATURE=0.3

# Ollama context window size (default: 4096 3000~3100 English Words,
# increase for very long JDs)
# ATS_LLM_NUM_CTX=4096

# Two-pass domain-aware LLM expansion (1/true/yes to enable)
# Pass 1 infers relevant domains, pass 2 expands scoped keywords. ~2x latency.
# But higher precision for very long JDs with many domains.
ATS_LLM_TWO_PASS=false
# Two-pass temperatures: P1 domain classification (default: 0.2), P2 keyword expansion (default: 0.5)
# ATS_LLM_TEMPERATURE_P1=0.2
# ATS_LLM_TEMPERATURE_P2=0.5

# LM Studio server URL (default: http://localhost:1234)
# ATS_LMSTUDIO_URL=http://localhost:1234

# MLX model (HuggingFace repo ID, used when backend is mlx or auto)
# ATS_MLX_MODEL=mlx-community/Qwen3-8B-4bit

# Enable cross-encoder reranking (1/true/yes to enable)
ATS_RERANK=false

# Page budget
# ATS_MAX_EXPERIENCE=3
# ATS_MAX_PROJECTS=4
# ATS_MIN_PROJECTS=4
# ATS_MAX_SKILL_LINES=4
# ATS_MAX_PROJECT_BULLETS=3
# ATS_MIN_PROJECT_BULLETS=3
# ATS_MAX_EXP_BULLETS=3
# ATS_MIN_EXP_BULLETS=3
# ATS_CHARS_PER_BULLET_LINE=80
# ATS_MAX_PAGE_LINES=72

# huggingface token for MLX LLM backend
# (leave empty if not using MLX or if your model is public)
HUGGINGFACE_TOKEN=

# "experience" or "projects" — higher-priority section is trimmed/dropped last
# ATS_SECTION_PRIORITY=experience